rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        getUserData(request.auth.uid).role in ['admin', 'super_admin'] ||
        request.auth.token.email == 'check22@gmail.com'
      );
    }

    // =========================
    // 🔐 Users Collection
    // =========================
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }
    
    // =========================
    // 📅 Events Collection
    // =========================
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // =========================
    // ✅ Attendance Collection
    // =========================
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if 
        (!isSignedIn() && request.resource.data.attendanceType == 'visitor') ||
        (isSignedIn() && request.resource.data.attendanceType == 'member' && request.resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // =========================
    // 🎟️ District Access Platform (Standalone)
    // =========================
    match /accessEvents/{eventId} {
      allow read, list: if true; 
      allow write: if isAdmin();
    }
    
    match /accessRegistrations/{regId} {
      allow create: if true;
      allow read, list, update, delete: if isAdmin();
    }

    // =========================
    // 💬 Communication Groups
    // =========================
    match /communicationGroups/{groupId} {
      allow read, write: if isAdmin();
    }

    // =========================
    // 💡 Project Ideas
    // =========================
    match /projectIdeas/{ideaId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.authorId;
      allow read: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /transactions/{transactionId} {
      allow read, create, update, delete: if isAdmin();
    }

    // =========================
    // 🏆 Points Entries
    // =========================
    match /pointsEntries/{entryId} {
      allow read, write: if isAdmin();
    }
    
    match /dailyTasks/{taskId} {
      allow read, write: if isAdmin();
    }
    
    match /tasks/{taskId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.assigneeIds || isAdmin());
      allow delete: if isAdmin();
    }

    match /tasks/{taskId}/comments/{commentId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && getUserData(request.auth.uid).id == resource.data.authorId;
    }
    
     match /tasks/{taskId}/activity/{activityId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() || isAdmin();
        allow update, delete: if isAdmin();
    }
  }
}